{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/index.ts", "src/preload.ts", "src/types/**/*", "forge.config.js"],
  "exclude": ["vite.config.ts", "src/renderer/**/*"]
}